SCRAPER_PORT=3555

# Сколько отзывов максимум собирать за один скрейп. Должно быть кратно 50
# (размер страницы fetchReviews) — иначе последний неполный батч исказит
# проверку "собрано столько же, сколько запрошено" (см. IncompleteScrapeError).
TARGET_REVIEWS_COUNT=500

# Сколько подряд итераций скролла без новых отзывов считать поводом
# остановиться (страховка от бесконечного цикла, если организация физически
# меньше TARGET_REVIEWS_COUNT или прекратила отдавать данные).
MAX_IDLE_SCROLLS=5

# Сколько ждать ответ fetchReviews на одной попытке скролла, мс.
FETCH_RESPONSE_TIMEOUT_MS=8000
