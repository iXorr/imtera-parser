APP_ID=app

NGINX_PORT=80
MYSQL_PORT=3306
VITE_PORT=5173

# NGINX_PORT также используется во frontend-сервисе (docker-compose.yml) для
# сборки VITE_API_URL=http://localhost:{NGINX_PORT}/api — backend наружу не
# проброшен, поэтому фронтенд достаёт API только через nginx

# MYSQL_DATABASE={APP_ID}_db, но он
# генерируется в docker-compose.yml

MYSQL_USER=admin
MYSQL_PASSWORD=admin
MYSQL_ROOT_PASSWORD=root

SCRAPER_PORT=4000

# Сколько отзывов максимум собирать за один скрейп. Должно быть кратно 50
# (размер страницы fetchReviews), НО НЕ БОЛЬШЕ 600: СКОРЕЕ ВСЕГО, ЭТО
# - ЛИМИТ САМОГО ЯНДЕКСА (т.к. и с обычной страницы больше 600 нельзя получить)
TARGET_REVIEWS_COUNT=500

# Сколько подряд итераций скролла без новых отзывов считать поводом
# остановиться (страховка от бесконечного цикла, если организация физически
# меньше TARGET_REVIEWS_COUNT или прекратила отдавать данные).
MAX_IDLE_SCROLLS=5

# Сколько ждать ответ fetchReviews на одной попытке скролла, мс.
FETCH_RESPONSE_TIMEOUT_MS=8000
